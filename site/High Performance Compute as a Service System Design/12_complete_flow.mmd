graph TB
    START[Researcher Submits Job<br/>sky launch train.yaml]
    
    subgraph "SkyPilot Layer"
        SP_PARSE[Parse Task Definition<br/>Resources, Storage, Env]
        SP_K8S[Generate Kubernetes<br/>Pod Specification]
    end
    
    subgraph "Kubernetes Control Plane"
        API[API Server<br/>Admission Control]
        KYV_POL[Kyverno Policy<br/>Inject EFA Env Vars]
        SCHED[Scheduler<br/>Find/Request Node]
    end
    
    subgraph "Karpenter Provisioning"
        KARP_EVAL[Evaluate NodePool<br/>Select Instance Type]
        KARP_LAUNCH[Launch EC2 Instance<br/>+ User Data<br/>+ Placement Group]
    end
    
    subgraph "Node Bootstrap"
        BOOT_RAID[RAID0 NVMe Disks<br/>mdadm --create]
        BOOT_FSX[Mount FSx via CSI<br/>PersistentVolume]
        BOOT_EFA[Attach EFA ENIs<br/>VPC CNI Plugin]
        BOOT_REG[Register with K8s<br/>Advertise Resources]
    end
    
    subgraph "Container Runtime"
        SOCI_LOAD[SOCI Snapshotter<br/>Lazy-load Image]
        POD_START[Start Training Pod<br/>Environment Ready]
    end
    
    subgraph "Training Execution"
        DATA_LOAD[Load Dataset<br/>from FSx Lustre<br/>1200 Gbps]
        TRAIN[Training Loop<br/>Multi-GPU/Multi-node<br/>NCCL over EFA]
        CKPT[Write Checkpoints<br/>to NVMe MOUNT_CACHED<br/>Async to S3]
    end
    
    subgraph "Observability"
        LOGS[Fluent Bit Collect<br/>Tag with Task ID]
        CW[CloudWatch Streams<br/>task-sky-job-123]
    end
    
    subgraph "Spot Interruption Path"
        SPOT_WARN[Spot Warning<br/>2-min Notice]
        SIGTERM[Send SIGTERM<br/>to Pod]
        GRACEFUL[Signal Handler<br/>Emergency Checkpoint]
        RESCHED[SkyPilot Reschedule<br/>on New Node]
    end
    
    START --> SP_PARSE
    SP_PARSE --> SP_K8S
    SP_K8S --> API
    API --> KYV_POL
    KYV_POL --> SCHED
    
    SCHED -->|No Node Available| KARP_EVAL
    KARP_EVAL --> KARP_LAUNCH
    
    KARP_LAUNCH --> BOOT_RAID
    BOOT_RAID --> BOOT_FSX
    BOOT_FSX --> BOOT_EFA
    BOOT_EFA --> BOOT_REG
    
    BOOT_REG --> SCHED
    SCHED -->|Schedule Pod| SOCI_LOAD
    
    SOCI_LOAD --> POD_START
    POD_START --> DATA_LOAD
    DATA_LOAD --> TRAIN
    TRAIN --> CKPT
    
    TRAIN --> LOGS
    LOGS --> CW
    
    TRAIN -.->|Spot Event| SPOT_WARN
    SPOT_WARN --> SIGTERM
    SIGTERM --> GRACEFUL
    GRACEFUL --> CKPT
    GRACEFUL --> RESCHED
    RESCHED -.->|Resume| DATA_LOAD
    
    COMPLETE[Job Complete<br/>Results in S3<br/>Logs in CloudWatch]
    
    CKPT --> COMPLETE
    
    style SP_PARSE fill:#4A90E2
    style KARP_EVAL fill:#E27D60
    style BOOT_RAID fill:#F4A261
    style BOOT_FSX fill:#85C88A
    style BOOT_EFA fill:#F4A261
    style SOCI_LOAD fill:#9B59B6
    style TRAIN fill:#4A90E2
    style GRACEFUL fill:#85C88A
    style COMPLETE fill:#85C88A,stroke:#2D5F3E,stroke-width:3px
